# Grokestrator Mac release credentials.
#
# Copy this file to scripts/release.env and fill in the values.
# release.env is gitignored. release.env.example IS tracked, as documentation.
#
# Once filled in, `scripts/build-mac-release.sh` will produce a fully
# signed + notarized + stapled DMG ready for public distribution.
#
# Without these env vars set, the script falls back to DRY-RUN mode:
# ad-hoc-signed, no notarization, output labeled "-DRY-RUN.dmg".

# ---------------------------------------------------------------------------
# APPLE_TEAM_ID
# ---------------------------------------------------------------------------
# Your 10-character Apple Developer Team ID.
# Find it: https://developer.apple.com/account → Membership → Team ID.
# (For SourcePath Labs, this is the team that owns the Developer ID
# Application cert — make sure it's the company team, not your personal one.)
APPLE_TEAM_ID="REPLACE_ME"

# ---------------------------------------------------------------------------
# NOTARY_KEYCHAIN_PROFILE
# ---------------------------------------------------------------------------
# A keychain profile name that holds your notarytool credentials.
# Set up ONCE on this Mac with:
#
#   xcrun notarytool store-credentials grokestrator-notary \
#     --apple-id "you@sourcepathlabs.ai" \
#     --team-id  "$APPLE_TEAM_ID" \
#     --password "APP_SPECIFIC_PASSWORD"
#
# Where APP_SPECIFIC_PASSWORD is generated at https://appleid.apple.com →
# Sign-In and Security → App-Specific Passwords. The password is stored
# in the macOS keychain; only the profile name needs to live here.
NOTARY_KEYCHAIN_PROFILE="grokestrator-notary"

# ---------------------------------------------------------------------------
# APP_STORE_CONNECT_KEY_ID + APP_STORE_CONNECT_ISSUER_ID  (iOS upload only)
# ---------------------------------------------------------------------------
# App Store Connect API key — used by build-ios-release.sh to upload .ipa
# builds to TestFlight via `xcrun altool`. Not needed for the Mac script.
#
# Set up ONCE in App Store Connect:
#   appstoreconnect.apple.com → Users and Access → Integrations → Keys
#   → "+" → role "App Manager" (or higher) → download AuthKey_XXXX.p8
#
# The .p8 file can only be downloaded ONCE. Save it at:
#   ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
#
# altool finds it by convention from KEY_ID alone, so the path doesn't
# need to live here — just the IDs.
APP_STORE_CONNECT_KEY_ID="REPLACE_ME"      # 10-character Key ID from the portal
APP_STORE_CONNECT_ISSUER_ID="REPLACE_ME"   # UUID — top of the Keys page

# ---------------------------------------------------------------------------
# MARKETING_VERSION  (optional)
# ---------------------------------------------------------------------------
# Defaults to whatever is set in project.yml. Override here for one-off
# release builds without touching the project spec.
# MARKETING_VERSION="0.1.0"
