# Grokestrator release credentials.
#
# Copy to scripts/release.env (gitignored) for local releases, or map the same
# values to GitHub repository secrets for CI (Signed Release workflow).
#
# Local quick start:
#   cp scripts/release.env.example scripts/release.env
#   # fill in values, run xcrun notarytool store-credentials (see below)
#   scripts/release-preflight.sh
#   scripts/build-release.sh
#
# Once configured, build-mac-release.sh produces a signed + notarized + stapled
# DMG; build-ios-release.sh uploads to TestFlight.

# ---------------------------------------------------------------------------
# APPLE_TEAM_ID  (required for signed releases)
# ---------------------------------------------------------------------------
# SourcePath Labs paid team. Also set in project.yml DEVELOPMENT_TEAM.
APPLE_TEAM_ID="GS8DPK5RPN"

# ---------------------------------------------------------------------------
# Mac notarization — pick ONE path
# ---------------------------------------------------------------------------

# LOCAL (recommended on your Mac): keychain profile from notarytool.
# Set up once:
#   xcrun notarytool store-credentials grokestrator-notary \
#     --apple-id "you@sourcepathlabs.ai" \
#     --team-id  "$APPLE_TEAM_ID" \
#     --password "APP_SPECIFIC_PASSWORD"
NOTARY_KEYCHAIN_PROFILE="grokestrator-notary"

# CI (GitHub Actions): App Store Connect API key also works for notarization
# when NOTARY_KEYCHAIN_PROFILE is unset. Set these repository secrets:
#   APP_STORE_CONNECT_KEY_ID
#   APP_STORE_CONNECT_ISSUER_ID
#   APP_STORE_CONNECT_API_KEY_BASE64   (contents of AuthKey_XXXX.p8, base64)

# ---------------------------------------------------------------------------
# Developer ID certificate (CI only — local Mac uses Keychain)
# ---------------------------------------------------------------------------
# Export your "Developer ID Application" cert as .p12, then base64-encode:
#   base64 -i DeveloperID.p12 | pbcopy
# GitHub secrets:
#   APPLE_CERTIFICATE_BASE64
#   APPLE_CERTIFICATE_PASSWORD

# ---------------------------------------------------------------------------
# App Store Connect API key (iOS TestFlight + CI notarization)
# ---------------------------------------------------------------------------
# appstoreconnect.apple.com → Users and Access → Integrations → Keys
# Download AuthKey_XXXX.p8 ONCE → ~/.appstoreconnect/private_keys/
APP_STORE_CONNECT_KEY_ID="REPLACE_ME"
APP_STORE_CONNECT_ISSUER_ID="REPLACE_ME"

# Optional explicit path (otherwise ~/.appstoreconnect/private_keys/ is used):
# APP_STORE_CONNECT_API_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXX.p8"

# ---------------------------------------------------------------------------
# MARKETING_VERSION  (optional)
# ---------------------------------------------------------------------------
# MARKETING_VERSION="0.3.5"